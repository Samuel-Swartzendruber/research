E_100, j_100 = zip(*data_100)
E_10,  j_10  = zip(*data_10)

# ── iR Compensation ───────────────────────────────────────────────────────────

d        = 1          # cm  — RE tip to WE surface distance
kappa    = 0.1          # S/cm — solution conductivity


R_u = d / (kappa)
print(f"Rᵤ = {R_u:.2f} Ω   (d={d} cm, κ={kappa} S/cm)")

# E_corr = E_meas - j[mA/cm²] * area[cm²] / 1000 * R_u[Ω]
#        = E_meas - i[A] * R_u[Ω]
def ir_correct(E, j):
    return [e - (jj / 1000) * R_u for e, jj in zip(E, j)]

E_100_corr = ir_correct(E_100, j_100)
E_10_corr  = ir_correct(E_10,  j_10)

# ── Plot ──────────────────────────────────────────────────────────────────────

fig, axes = plt.subplots(1, 2, figsize=(13, 5), sharey=True)
fig.suptitle('Cyclic Voltammetry', fontsize=13, fontweight='bold')

plot_sets = [
    (axes[0], E_100,      j_100, E_10,     j_10,  'Raw (no correction)'),
    (axes[1], E_100_corr, j_100, E_10_corr, j_10, f'iR Corrected  ($R_u$ = {R_u:.1f} Ω)'),
]

for ax, e100, j100, e10, j10, title in plot_sets:
    ax.plot(e100, j100, color='#1f77b4', linewidth=2.0, label=r'100 mV s$^{-1}$', zorder=3)
    ax.plot(e10,  j10,  color='#d62728', linewidth=2.0, label=r'10 mV s$^{-1}$',  zorder=3)
    ax.axhline(0, color='black', linewidth=0.8, linestyle='--', alpha=0.5)
    ax.set_xlabel('Potential vs. RE  (V)', fontsize=11)
    ax.set_title(title, fontsize=11)
    ax.legend(fontsize=9, framealpha=0.9)
    ax.xaxis.set_minor_locator(ticker.AutoMinorLocator())
    ax.yaxis.set_minor_locator(ticker.AutoMinorLocator())
    ax.tick_params(which='both', direction='in', top=True, right=True)
    ax.grid(True, which='major', linestyle=':', linewidth=0.6, alpha=0.6)

    # Annotate peaks on 100 mV/s
    i_pa = max(j100);  E_pa = e100[list(j100).index(i_pa)]
    i_pc = min(j100);  E_pc = e100[list(j100).index(i_pc)]
    ax.annotate(f'$E_{{pa}}$={E_pa:.3f} V', xy=(E_pa, i_pa),
                xytext=(E_pa - 0.18, i_pa - 2), fontsize=7.5, color='#1f77b4',
                arrowprops=dict(arrowstyle='->', color='#1f77b4', lw=1.1))
    ax.annotate(f'$E_{{pc}}$={E_pc:.3f} V', xy=(E_pc, i_pc),
                xytext=(E_pc + 0.08, i_pc + 3), fontsize=7.5, color='#1f77b4',
                arrowprops=dict(arrowstyle='->', color='#1f77b4', lw=1.1))

axes[0].set_ylabel(r'Current Density  (mA cm$^{-2}$)', fontsize=11)
fig.tight_layout()

