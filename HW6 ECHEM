#Now get peak separation and calculate n
delta_E = E_pa - E_pc
print(f"Peak separation ΔE = {delta_E:.3f} V")

E_0 = (E_pa + E_pc) / 2
print(f"Formal potential E₀ = {E_0:.3f} V")

# For a reversible one-electron transfer at 25°C, ΔE should be ~59 mV
# ΔE = (2.303 * R * T) / (n * F)
R = 8.314  # J/(mol·K)
T = 298    # K
F = 96485  # C/mol
n = (2.303 * R * T) / (delta_E * F)
print(f"Number of electrons n = {n:.2f}")


#for perferctly reversible, ΔE should be 59 mV for 1e- transfer, so n = 1
delta_E_ideal = 0.059  # V
n_ideal = (2.303 * R * T) / (delta_E_ideal * F)
print(f"Ideal number of electrons n (for ΔE=59 mV) = {n_ideal:.2f}")