#Problem 2E
#Calculate transition dipole matrix elements for all 0 --> n transitions up to n_max for both HCl and CO.  We will now include the quadratic term of the expansion

#Where ⟨𝑛|𝜇|0⟩ = 𝝁′⟨𝑛|𝜇|0⟩ + 0.5 𝝁''⟨𝑛|x^2|0⟩.

#We will do this as a function of the anharmonicity parameter x_e, which is as follows
# 𝑥_𝑒 = ℏ𝑎 / sqrt(8 m_R D_e), where m_R is the reduced mass and a is the parameter we calculated earlier
def anharmonicity_parameter(a_Ainv, mu_amu, De_eV):
    De_J = De_eV * EV_TO_J
    mu = mu_amu * AMU_TO_KG
    a_m = a_Ainv / ANGSTROM_TO_M  # Å^-1 → m^-1
    x_e = HBAR * a_m / np.sqrt(8 * mu * De_J)
    return x_e

# Calculate anharmonicity parameters
x_e_HCl = anharmonicity_parameter(a_Ainv_HCl, mu_HCl, De_eV_HCl)
x_e_CO = anharmonicity_parameter(a_Ainv_CO, mu_CO, De_eV_CO)

print(f"HCl anharmonicity parameter x_e: {x_e_HCl:.4e}")
print(f"CO anharmonicity parameter x_e: {x_e_CO:.4e}")

#Calculate transition dipole matrix elements including quadratic term
def transition_dipole_with_quadratic(n_initial, n_final, R_A, De_eV, a_Ainv, Re_A, mu_amu):
    psi_initial = morse_wavefunction(n_initial, R_A, De_eV, a_Ainv, Re_A, mu_amu)
    psi_final = morse_wavefunction(n_final, R_A, De_eV, a_Ainv, Re_A, mu_amu)
    
    # Linear term
    mu_linear = np.trapezoid(psi_initial * R_A * psi_final, R_A)
    
    # Quadratic term
    mu_quadratic = 0.1*0.5* np.trapezoid(psi_initial * R_A**2 * psi_final, R_A)  # Here I set mu'' = mu' / 10.
    return mu_linear + mu_quadratic

# Calculate line strengths for HCl with quadratic term
print("\nHCl Line Strengths with Quadratic Term:")
for n_final in range(1, 4):
    mu = transition_dipole_with_quadratic(0, n_final, R_A, De_eV_HCl, a_Ainv_HCl, Re_A_HCl, mu_HCl)
    S = mu**2
    print(f"0 --> {n_final}: S = {S:.4e}")

# Calculate line strengths for CO with quadratic term
print("\nCO Line Strengths with Quadratic Term:")
for n_final in range(1, 4):
    mu = transition_dipole_with_quadratic(0, n_final, R_A, De_eV_CO, a_Ainv_CO, Re_A_CO, mu_CO)     
    S = mu**2
    print(f"0 --> {n_final}: S = {S:.4e}")

#Compare results with and without quadratic term with u'' = u' / 10
print("\nComparison with and without Quadratic Term - HCl:")
for n_final in range(1, 4):
    mu_linear = transition_dipole(0, n_final, R_A, De_eV_HCl, a_Ainv_HCl, Re_A_HCl, mu_HCl)
    mu_quadratic = transition_dipole_with_quadratic(0, n_final, R_A, De_eV_HCl, a_Ainv_HCl, Re_A_HCl, mu_HCl)
    print(f"0 --> {n_final}: Linear = {mu_linear**2:.4e}, Quadratic = {mu_quadratic**2:.4e}")

print("\nComparison with and without Quadratic Term - CO:")
for n_final in range(1, 4):
    mu_linear = transition_dipole(0, n_final, R_A, De_eV_CO, a_Ainv_CO, Re_A_CO, mu_CO)
    mu_quadratic = transition_dipole_with_quadratic(0, n_final, R_A, De_eV_CO, a_Ainv_CO, Re_A_CO, mu_CO)
    print(f"0 --> {n_final}: Linear = {mu_linear**2:.4e}, Quadratic = {mu_quadratic**2:.4e}")
