#Here we will calculate line strength of 0 --> 1, 0 --> 2, and 0 --> 3 for both HCl and CO.  We will let mu = 1. 

#For the transition, we will calculate mu_kl for the transition, which is done using 𝜇_𝑚𝑚 = ∫ 𝜓𝑚 ∗ 𝑥 𝜓n dx and have the line strength S = |mu|^2

def transition_dipole(n_initial, n_final, R_A, De_eV, a_Ainv, Re_A, mu_amu):
    psi_initial = morse_wavefunction(n_initial, R_A, De_eV, a_Ainv, Re_A, mu_amu)
    psi_final = morse_wavefunction(n_final, R_A, De_eV, a_Ainv, Re_A, mu_amu)
    
    # Transition dipole moment (assuming x = R for simplicity)
    mu_mn = np.trapezoid(psi_initial * R_A * psi_final, R_A)
    
    return mu_mn

# Calculate line strengths for HCl
print("HCl Line Strengths:")
for n_final in range(1, 4):
    mu = transition_dipole(0, n_final, R_A, De_eV_HCl, a_Ainv_HCl, Re_A_HCl, mu_HCl)
    S = mu**2
    print(f"0 --> {n_final}: S = {S:.4e}") 

# Calculate line strengths for CO
print("\nCO Line Strengths:")
for n_final in range(1, 4):
    mu = transition_dipole(0, n_final, R_A, De_eV_CO, a_Ainv_CO, Re_A_CO, mu_CO)
    S = mu**2
    print(f"0 --> {n_final}: S = {S:.4e}")



