def write_xyz_string(atomic_numbers, coords):
    from ase.data import chemical_symbols
    symbols = [chemical_symbols[z] for z in atomic_numbers]
    lines = []
    lines.append(str(len(symbols)))
    lines.append("Transition state")
    for sym, (x, y, z) in zip(symbols, coords):
        lines.append(f"{sym}  {x:.6f}  {y:.6f}  {z:.6f}")
    return "\n".join(lines)

i = 1
xyz_str = write_xyz_string(reactant['charges'][i], reactant['positions'][i])

view = py3Dmol.view(width=600, height=400)
view.addModel(xyz_str, "xyz")
view.setStyle({"stick": {}, "sphere": {"scale": 0.3}})
view.zoomTo()
view.show()
